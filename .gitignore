# Arcade Video Scanner - Git Ignore

# User Data (CRITICAL - DO NOT UPLOAD)
# This directory contains your local thumbnails, previews, and video cache
arcade_data/

# Python artifacts
__pycache__/
*.pyc
*.pyo
*.pyd
.Python
env/
venv/
.venv/
.env

# macOS system files
.DS_Store

# Logs
*.log
server_log.txt
status.txt

# Debug/Development files (ad-hoc scripts, NOT the tests/ suite)
debug_*.py
check_*.py
verify_*.py
# Note: tests/test_*.py are intentionally tracked — see tests/ directory

# Temporary files
*.tmp
*.bak
*.swp
*~

# IDE
.idea/
.vscode/
*.code-workspace

# Scripts (Local paths)
*.sh
*.zip
!run.sh

# Generated HTML report (user-specific)
video_dashboard.html
*.egg-info/
